{
    "name": "muhindo/laravel-admin",
    "description": "Modern Laravel Admin Panel - A comprehensive admin interface builder for Laravel with PHP 8.1+ and Bootstrap 4+ support",
    "type": "library",
    "keywords": ["laravel", "admin", "grid", "form", "crud", "panel", "backend", "php8", "bootstrap4"],
    "homepage": "https://github.com/muhindo/laravel-admin",
    "license": "MIT",
    "authors": [
        {
            "name": "Your Name",
            "email": "your.email@example.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "laravel/framework": "^10.0|^11.0",
        "symfony/dom-crawler": "^6.0|^7.0",
        "doctrine/dbal": "^3.5|^4.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "phpunit/phpunit": "^10.0",
        "mockery/mockery": "^1.5",
        "fakerphp/faker": "^1.20",
        "intervention/image": "^2.7|^3.0",
        "spatie/phpunit-watcher": "^1.23"
    },
    "autoload": {
        "psr-4": {
            "Muhindo\\Admin\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/",
            "Tests\\Models\\": "tests/models/",
            "Tests\\Controllers\\": "tests/controllers/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage",
        "format": "vendor/bin/php-cs-fixer fix",
        "analyse": "vendor/bin/phpstan analyse"
    },
    "suggest": {
        "intervention/image": "Required for handling and manipulation of upload images (^2.7|^3.0).",
        "spatie/eloquent-sortable": "Required to build orderable grid functionality."
    },
    "extra": {
        "laravel": {
            "providers": [
                "Muhindo\\Admin\\AdminServiceProvider"
            ],
            "aliases": {
                "Admin": "Muhindo\\Admin\\Facades\\Admin"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
